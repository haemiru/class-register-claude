# ─────────────────────────────────────────────────────────
# 클라이언트(브라우저) 노출 OK — VITE_ 접두사 필수
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# 서버 전용(Serverless) — 절대 클라이언트에 노출 금지
# Design Ref: §9 Security — VITE_ 접두사 없이 둘 것
# ─────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxx
# 관리자 허용 Google 계정(쉼표로 여러 개). Supabase Auth에서 Google provider 활성화 필요.
ADMIN_EMAILS=you@gmail.com
